# Copy this file to .env and fill in values.

# Database — SQLite for local dev. For production (Vercel/Netlify) use Postgres:
#   DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# Auth — required
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google sign-in — optional (button hidden if blank)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Real Claude AI — optional (smart mock used if blank)
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
